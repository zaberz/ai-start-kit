VITE_SUPABASE_URL=https://demo.supabase.co
VITE_SUPABASE_KEY=sb_publishable_demo

# 数据迁移脚本使用 (service_role key，请勿暴露到前端)
SUPABASE_URL=https://demo.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# MySQL dump 文件迁移 (migrate:data)
MYSQL_DUMP_PATH=./ficus_2026-05-02_01-34-16_mysql_data.sql

# 线上 MySQL 直连迁移 (migrate:live)
MYSQL_HOST=your-mysql-host.com
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ficus

# 迁移用户时的默认密码
DEFAULT_PASSWORD=LaFibre2024!
